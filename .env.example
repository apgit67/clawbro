# Required
ANTHROPIC_API_KEY=your_key_here

# Optional: Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=  # Comma-separated Telegram user IDs for auth

# Optional: Discord
DISCORD_BOT_TOKEN=

# Optional: Ollama offline fallback
OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3
OLLAMA_HOST=http://localhost:11434
# Required for cloud-hosted Ollama models (e.g. glm-5.1:cloud, deepseek-v3.1:671b-cloud).
# Generate a key at https://ollama.com/settings/keys
# Leave blank for local-only models — they don't need a key.
OLLAMA_API_KEY=

# Optional: Override default paths
CLAWBRO_DB_PATH=~/.clawbro/memory.db
CLAWBRO_LOG_PATH=~/.clawbro/clawbro.log

# Model settings
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048
